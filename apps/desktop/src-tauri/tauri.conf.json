{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Helix",
  "version": "0.1.0",
  "identifier": "com.ameno.helix",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Helix",
        "width": 1280,
        "height": 820,
        "minWidth": 1280,
        "minHeight": 820,
        "maxWidth": 1280,
        "maxHeight": 820,
        "resizable": false,
        "maximizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/helix-api"
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "hardenedRuntime": false,
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFBNDAwRjk1QkE4Qjg4QkQKUldTOWlJdTZsUTlBcXRVSVlwREFXck91eCtNbnZyaEg1Ri9LZzBIYjl1RHpSNXREMVRtMlY0TUMK",
      "endpoints": [
        "https://github.com/joltzeal/helix/releases/latest/download/latest.json"
      ]
    }
  }
}
